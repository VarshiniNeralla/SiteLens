# vLLM OpenAI-compatible API (POST …/chat/completions)
LLM_BASE_URL=http://172.20.7.22:8000/v1
# Optional: override if your server exposes chat at a different path (404 fixes)
# LLM_CHAT_URL=http://172.20.7.22:8000/v1/chat/completions
LLM_MODEL=default
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=700
LLM_PROVIDER=local
GROQ_API_KEY=

# Storage (relative to backend working directory or absolute paths)
UPLOAD_DIR=uploads
REPORTS_DIR=reports
DATA_DIR=data

# PPT layout config (JSON)
PPT_LAYOUT_PATH=data/ppt_layout.json

# Optional: existing .pptx used as slide master (python-pptx loads it; new slides still follow ppt_layout.json)
# PPT_TEMPLATE_PATH=

# LibreOffice (PDF export). Windows default often:
# LIBREOFFICE_SOFFICE=C:\Program Files\LibreOffice\program\soffice.exe
LIBREOFFICE_SOFFICE=soffice

# Optional: max image dimension after upload (pixels)
IMAGE_MAX_DIMENSION=2048
IMAGE_JPEG_QUALITY=85

# API
API_PREFIX=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=sitelens_prod
